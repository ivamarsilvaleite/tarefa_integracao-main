          "name": "cidades",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Cidades retorna 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Resposta possui cidades\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData).to.have.property(\"cidades\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Lista não vazia\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.cidades.length).to.be.above(0);\r",
                  "});"
                ],
